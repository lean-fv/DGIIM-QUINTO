{{\*\bkmkstart RCL_2002_1764-1#A.1(20080916)[spa]}{\*\bkmkend RCL_2002_1764-1#A.1(20080916)[spa]}}\qj \hyphpar0 \cbpat0 {\sa0\sb200\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b0 \i0 \strike0 \ul0 
{{\*\bkmkstart RCL_2002_1764-1_A.1}{\*\bkmkend RCL_2002_1764-1_A.1}}\qj \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b0 \i0 \strike0 \ul0 }

\ql \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b \i0 \strike0 \ul0 Artículo 1. Contenido de la solicitud de registro \par}

\qj \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b0 \i0 \strike0 \ul0 
\qj \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs18 \cf1 \b0 \i0 \strike0 \ul0 
\qj \hyphpar0 \cbpat0 {\sa270\sb270\li0\ri0\fi0\sl288\slmult1 \f10 \fs18 \cf1 \b0 \i0 \strike0 \ul0 {{\trowd\lastrow\cbpat0 \clcbpat20 \clpadl90\clpadfl3\clpadr90\clpadfr3\clpadt90\clpadft3\clpadb0\clpadfb3\clbrdrt\brdrs\brdrw20\brdrcf21\clbrdrb\brdrs\brdrw20\brdrcf21\clbrdrl\brdrs\brdrw20\brdrcf21\clbrdrr\brdrs\brdrw20\brdrcf21\clwWidth8899\cellx8899 \intbl 
\qj \hyphpar0 \cbpat0 \sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f11 \fs18 \cf1 \b0 \i0 \strike0 \ul0 
\qj \hyphpar0 \cbpat0 \sa100\sb100\li0\ri0\fi360\sl288\slmult1 \f11 \fs18 \cf1 \b \i0 \strike0 \ul0 Notas de vigencia\intbl\par

\qj \hyphpar0 \cbpat0 \sa0\sb0\li288\ri0\fi0\sl288\slmult1 \f11 \fs18 \cf1 \b0 \i0 \strike0 \ul0 
\qj \hyphpar0 \cbpat0 \sa0\sb0\li288\ri0\fi0\sl288\slmult1 \f11 \fs18 \cf1 \b0 \i0 \strike0 \ul0 
\qj \hyphpar0 \cbpat0 \sa0\sb0\li288\ri0\fi0\sl288\slmult1 \f11 \fs18 \cf1 \b0 \i0 \strike0 \ul0 Ap. 1 c) modificado por {\f11 \fs18 \cf2 \b0 \i0 \strike0 \ul art. 4.1} de {\f11 \fs18 \cf2 \b0 \i0 \strike0 \ul Real Decreto núm. 1431/2008, de 29 de agosto. RCL\\2008\\1606}.\intbl\par
