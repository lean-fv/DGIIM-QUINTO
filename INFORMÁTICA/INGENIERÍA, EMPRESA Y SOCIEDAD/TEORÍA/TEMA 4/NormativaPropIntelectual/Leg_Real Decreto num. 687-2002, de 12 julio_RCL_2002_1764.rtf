\ql \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b \i0 \strike0 \ul0 Artículo 20. Examen de oficio y suspensión del expediente \par}

\qj \hyphpar0 \cbpat0 {\sa0\sb0\li0\ri0\fi0\sl288\slmult1 \f10 \fs20 \cf1 \b0 \i0 \strike0 \ul0 
